# Telegram bot credentials (create a bot via @BotFather, get your chat id via @userinfobot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Postgres connection string.
# Local dev: postgresql://jobsradar:jobsradar@localhost:5433/jobsradar (see docker-compose.yml)
# Production: your Neon connection string (postgresql://...@...neon.tech/...?sslmode=require)
DATABASE_URL=

# Minutes between poll cycles (only used by `npm run start`, the local cron loop)
POLL_INTERVAL_MIN=15

# Jobs scoring >= this value trigger a Telegram alert (0-100). All relevant jobs are stored regardless.
SCORE_THRESHOLD=45

# LLM scoring (Phase 3). Set an Anthropic API key (console.anthropic.com) to score jobs with
# Claude Haiku 4.5 instead of the keyword scorer. Leave empty to use the free keyword scorer.
ANTHROPIC_API_KEY=

# Scorer selection. Default is the free keyword scorer. Set to 'llm' to score with Claude
# (requires ANTHROPIC_API_KEY) — this costs money, so it's explicit opt-in, never automatic.
SCORER=keyword

# Dashboard (Phase 2) shared password. Set a strong value in Vercel env for production.
DASHBOARD_PASSWORD=

# TheirStack (optional second, market-wide job source — free key at theirstack.com).
# CREDIT WARNING: the free tier bills 1 API credit PER JOB RETURNED (200/month). The poller
# fetches incrementally and enforces THEIRSTACK_MONTHLY_BUDGET, but keep the filters tight.
THEIRSTACK_API_KEY=
# Optional tuning (defaults shown): posted-age sanity cap / page size (free-tier max 25) /
# pagination cap per run / hard monthly job budget.
# THEIRSTACK_MAX_AGE_DAYS=14
# THEIRSTACK_LIMIT=25
# THEIRSTACK_MAX_PAGES=4
# THEIRSTACK_MONTHLY_BUDGET=180
