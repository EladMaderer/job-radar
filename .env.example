# Telegram bot credentials (create a bot via @BotFather, get your chat id via @userinfobot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Postgres connection string.
# Local dev: postgresql://jobsradar:jobsradar@localhost:5433/jobsradar (see docker-compose.yml)
# Production: your Neon connection string (postgresql://...@...neon.tech/...?sslmode=require)
DATABASE_URL=

# Minutes between poll cycles (only used by `npm run start`, the local cron loop)
POLL_INTERVAL_MIN=15

# Jobs scoring >= this value trigger a Telegram alert (0-100). All relevant jobs are stored regardless.
SCORE_THRESHOLD=45

# Anthropic API key (console.anthropic.com). Powers BOTH: LLM job scoring (with SCORER=llm) and
# the resume-tailoring feature (design capture, tailoring, interview prep). Add it to Vercel's
# project env too — the dashboard functions need it there.
ANTHROPIC_API_KEY=

# Resume feature — optional overrides:
# LOCAL_CHROME_PATH: dev only — path to a local Chrome for PDF rendering (the Vercel binary can't
#   run on macOS). e.g. "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome". NEVER set in Vercel.
# LOCAL_CHROME_PATH=
# Per-task model overrides (defaults: capture/tailor = claude-sonnet-5, prep = claude-haiku-4-5):
# RESUME_CAPTURE_MODEL=
# RESUME_TAILOR_MODEL=
# RESUME_PREP_MODEL=

# Scorer selection. Default is the free keyword scorer. Set to 'llm' to score with Claude
# (requires ANTHROPIC_API_KEY) — this costs money, so it's explicit opt-in, never automatic.
SCORER=keyword

# Dashboard (Phase 2) shared password. Set a strong value in Vercel env for production.
DASHBOARD_PASSWORD=

# TheirStack (optional second, market-wide job source — free key at theirstack.com).
# CREDIT WARNING: billed 1 API credit PER JOB RETURNED. The poller fetches incrementally, caps
# each run at the remaining budget, and meters usage by billing period.
THEIRSTACK_API_KEY=
# Optional tuning (defaults shown, sized for the paid tier):
# THEIRSTACK_MAX_AGE_DAYS=14          # ongoing posted-age cap (days)
# THEIRSTACK_LIMIT=200                # page size (paid allows up to 500)
# THEIRSTACK_MAX_PAGES=10             # pagination cap per run
# THEIRSTACK_PERIOD_BUDGET=1400       # hard credit cap per BILLING PERIOD
# THEIRSTACK_BILLING_CYCLE_DAY=16     # day of month the plan renews (1-28)
# THEIRSTACK_BROAD_TITLES=false       # add bare "Software Engineer" titles — only with SCORER=llm live
